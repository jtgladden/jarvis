<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleDisplayName</key>
	<string>Jarvis</string>
	<key>CFBundleName</key>
	<string>Jarvis</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Jarvis uses your location to build a daily movement journal with visits, travel distance, and commute timing.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Jarvis uses background location to keep your movement journal up to date throughout the day.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Jarvis Health connects to your local Jarvis server on your home network so it can sync Apple Health data.</string>
	<key>NSHealthClinicalHealthRecordsShareUsageDescription</key>
	<string>Jarvis does not read clinical records in this starter build.</string>
	<key>NSHealthShareUsageDescription</key>
	<string>Jarvis reads your selected Apple Health data so it can summarize wellness trends for you.</string>
	<key>NSCameraUsageDescription</key>
	<string>Jarvis uses the camera to scan handwritten journal and study notes.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Jarvis uses the microphone for voice dictation in your journal and scripture notes.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Jarvis transcribes your voice into journal and scripture study notes.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Jarvis reads photos taken on each day to show a photo of the day in your journal.</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
	<key>JarvisLocalAPIBaseURL</key>
	<string>http://192.168.0.198:8000/api</string>
	<key>JarvisProductionAPIBaseURL</key>
	<string>https://jarvis.jarom.ink/api</string>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
	</array>
	<key>UILaunchScreen</key>
	<dict/>
</dict>
</plist>
