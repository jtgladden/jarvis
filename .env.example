OPENAI_API_KEY=your_openai_api_key
API_IMAGE=ghcr.io/your-github-user-or-org/jarvis-api:latest
WEB_IMAGE=ghcr.io/your-github-user-or-org/jarvis-web:latest
OPENAI_MAX_EMAILS_PER_RUN=15
OPENAI_EMAIL_BODY_PREVIEW_CHARS=0
# Persistent local state inside Docker is stored in /data by docker-compose.yml.
# You usually do not need to set these manually unless you want custom paths.
# JOURNAL_DB=/data/journal_entries.db
# TASKS_DB=/data/tasks.db
# CLASSIFICATION_CACHE_DB=/data/classification_cache.db
# CLASSIFICATION_GUIDANCE_FILE=/data/classification_guidance.json
# Public browser origins allowed to call the backend directly, if needed.
# On a server deployment, set this to your real site URL, e.g. https://jarvis.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Browser-facing API base. With the bundled Next.js proxy, this should usually stay /api.
NEXT_PUBLIC_API_BASE=/api
# Internal proxy target used by the Next.js container to reach the API container.
# In Docker Compose this should usually stay http://api:8000
API_PROXY_TARGET=http://api:8000
