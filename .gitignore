credentials.json
app/__pycache__
token.json
.env
.env.local
.deriveddata/
# SQLite domain databases (one .db per domain) + WAL sidecars — never committed.
# Glob so new domain stores are ignored automatically.
data/*.db
data/*.db-wal
data/*.db-shm
data/job_alerts_email_cache.json

# Cached rasterized journal-scan page images (regenerable from source PDFs)
data/journal_import_pages/

# Permanent per-entry copies of scanned source pages (user data, not committed)
data/journal_entry_photos/

# Local-only dummy/test journal data + seeder (never deploy to the server)
data/_dummy_journal_dates.json
scripts/seed_dummy_journal.py

# Xcode per-user IDE state (not useful to other contributors)
*.xcuserstate
xcuserdata/

# Claude Code local settings (machine-specific tool permissions)
.claude/settings.local.json
